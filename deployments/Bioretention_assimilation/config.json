{
    "deployment": {
        "name": "Bioretention_assimilation",
        "model_file": "model/Bioretention.ohq",
        "viz_file": "viz_bioretention.json",
        "port": 8087
    },
    "runtime": {
        "weather_source": "openmeteo_historical",
        "latitude": 38.91088,
        "longitude": -76.98569,
        "interval": "1day",
        "forecast_horizon": "",
        "start_datetime": "2020-01-03T00:00:00",
        "stop_datetime": "",
        "time_acceleration": 1000,
        "advance_to_observations": true,
        "state_variables": []
    },
    "observations": {
        "save_interval": "1hr",
        "noise_sigma": 0,
        "noise_correlation_time": "6hr"
    },
    "assimilation": {
        "truth_csv_url": "http://localhost:8086/outputs/selected_output.csv",
        "truth_meta_url": "http://localhost:8086/outputs/selected_output_meta.json",
        "poll_interval": "3day",
        "calibration_output_dir": "outputs/calibration",
        "calibration_observations": [
		"Underdrain flow (m3/day)",
		"Soil Moisture",
		"Pond water depth (m)"
    	]
    }
