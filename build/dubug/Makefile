####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/OHTwin/bin || mkdir -p $(INSTALL_ROOT)/opt/OHTwin/bin
	$(QINSTALL_PROGRAM) ../../build-qmake/bin/$(QMAKE_TARGET) $(INSTALL_ROOT)/opt/OHTwin/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/OHTwin/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/OHTwin/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

